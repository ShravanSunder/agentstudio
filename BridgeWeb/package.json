{
	"name": "@agentstudio/bridge-web",
	"version": "0.1.0",
	"description": "AgentStudio Bridge review surface foundation",
	"type": "module",
	"scripts": {
		"audit:assets": "node --experimental-strip-types scripts/audit-dependencies-and-assets.ts",
		"benchmark:viewer": "vitest --config vitest.benchmark.config.ts run",
		"build": "node --experimental-strip-types scripts/build-app.ts",
		"check": "oxlint --type-aware && node --experimental-strip-types scripts/check-bridgeweb-architecture.ts && oxfmt --check . && tsc --noEmit && pnpm run check:product-contract",
		"check:product-contract": "tsc --noEmit -p tsconfig.product-contract.json",
		"dev": "vite --host 127.0.0.1",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint",
		"lint:types": "oxlint --type-aware",
		"proof:visual:dev-server": "node --experimental-strip-types scripts/capture-bridge-viewer-dev-visual-proof.ts",
		"test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
		"test:unit": "vitest --config vitest.config.ts run",
		"test:integration": "pnpm run test:integration:node && pnpm run test:browser:integration",
		"test:integration:node": "vitest --config vitest.integration.config.ts run",
		"test:browser": "vitest --config vitest.browser.config.ts run --project integration-browser --tags-filter=!stress",
		"test:browser:integration": "vitest --config vitest.browser.config.ts run --project integration-browser --tags-filter=!stress",
		"test:browser:stress": "vitest --config vitest.browser.config.ts run --project integration-browser --tags-filter=stress",
		"test:dev-server": "node --experimental-strip-types scripts/verify-bridge-viewer-dev-server.ts",
		"test:dev-server:worktree": "node --experimental-strip-types scripts/verify-bridge-viewer-worktree-dev-server.ts",
		"test:e2e": "vitest --config vitest.e2e.config.ts run",
		"test:benchmark:browser": "node --experimental-strip-types scripts/bridge-viewer-browser-benchmark-runner.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@pierre/diffs": "1.2.10",
		"@pierre/trees": "1.0.0-beta.4",
		"@shikijs/core": "^4.2.0",
		"@shikijs/engine-javascript": "^4.2.0",
		"@shikijs/engine-oniguruma": "^4.2.0",
		"@shikijs/langs": "^4.2.0",
		"@shikijs/markdown-exit": "^4.2.0",
		"@shikijs/themes": "^4.2.0",
		"@vitejs/plugin-react": "^5.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "2.1.1",
		"dompurify": "^3.4.10",
		"lucide-react": "^1.21.0",
		"markdown-exit": "1.1.0-beta.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-resizable-panels": "^4.12.0",
		"shiki": "^4.2.0",
		"tailwind-merge": "3.3.1",
		"vite": "^7.0.0",
		"zod": "^4.4.3",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@tailwindcss/cli": "4.1.13",
		"@tailwindcss/postcss": "4.1.13",
		"@tsdown/css": "0.22.2",
		"@types/node": "25.9.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitest/browser": "4.1.10",
		"@vitest/browser-playwright": "4.1.10",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.0.0",
		"oxlint-tsgolint": "^0.23.0",
		"playwright": "^1.61.0",
		"postcss": "^8.5.15",
		"shadcn": "^4.11.0",
		"tailwindcss": "4.1.13",
		"tsdown": "0.22.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0"
}
