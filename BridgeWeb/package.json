{
	"name": "@agentstudio/bridge-web",
	"version": "0.1.0",
	"description": "AgentStudio Bridge review surface foundation",
	"type": "module",
	"scripts": {
		"build": "tsc --noEmit && vite build",
		"check": "oxlint --type-aware && oxfmt --check . && tsc --noEmit",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"lint": "oxlint",
		"lint:types": "oxlint --type-aware",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@vitejs/plugin-react": "^5.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"vite": "^7.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"jsdom": "^29.1.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.0.0",
		"oxlint-tsgolint": "^0.23.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0"
}
