#!/usr/bin/env bash
set -euo pipefail

while read -r _local_ref local_sha remote_ref _remote_sha; do
  [[ "$remote_ref" == refs/tags/* ]] || continue
  [[ "$local_sha" =~ ^0+$ ]] && continue
  tag="${remote_ref#refs/tags/}"
  if [[ "$tag" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "pre-push: refusing to push bare version tag '$tag'." >&2
    echo "pre-push: release workflow triggers on 'v*' — use 'v$tag' instead." >&2
    exit 1
  fi
done

exit 0
